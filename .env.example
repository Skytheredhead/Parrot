# Public application configuration
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_GATEWAY_ORIGIN=http://localhost:8787
NEXT_PUBLIC_SPACETIMEDB_URI=ws://localhost:3001
NEXT_PUBLIC_SPACETIMEDB_DATABASE=project-conversation-dev

# OIDC metadata only. Do not put client secrets in public-prefixed variables.
OIDC_ISSUER=https://identity.example.invalid/
OIDC_AUDIENCE=project-conversation

# Gateway/worker service configuration
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787
LOG_LEVEL=info
SPACETIMEDB_URI=http://localhost:3001
SPACETIMEDB_DATABASE=project-conversation-dev

# Provider adapters remain disabled until configured through approved secret storage.
OBJECT_STORAGE_PROVIDER=memory
SEARCH_PROVIDER=memory
EMAIL_PROVIDER=disabled
PUSH_PROVIDER=disabled
MODEL_PROVIDER=disabled

# Secret values are intentionally omitted. See each service README for its schema.
