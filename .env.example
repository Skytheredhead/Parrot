# Browser-safe application configuration. Only NEXT_PUBLIC_* values may enter a browser bundle.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_GATEWAY_ORIGIN=http://localhost:8080
NEXT_PUBLIC_SPACETIMEDB_URI=ws://127.0.0.1:3001
NEXT_PUBLIC_SPACETIMEDB_DATABASE=project-conversation-dev

# Gateway process
NODE_ENV=development
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_PROXY_CIDRS=

# Approved OIDC access-token profile. Production URLs must use HTTPS and JWKS must share the
# issuer origin. Provider client secrets belong in approved secret storage, never this file.
OIDC_ISSUER=https://identity.example.invalid/
OIDC_AUDIENCE=project-conversation
OIDC_JWKS_URI=https://identity.example.invalid/.well-known/jwks.json
OIDC_ALLOWED_TOKEN_TYPES=at+jwt
OIDC_MAX_TOKEN_AGE_SECONDS=900
OIDC_MAX_JWKS_BYTES=262144

# Short-lived database and agent capabilities
DB_TOKEN_AUDIENCE=project-conversation-database
DB_TOKEN_TTL_SECONDS=120
AGENT_STREAM_AUDIENCE=project-conversation-agent-stream
AGENT_STREAM_TTL_SECONDS=60
AGENT_STREAM_ORIGINS=wss://agent-stream.example.invalid

# File and search capability boundaries
UPLOAD_CAPABILITY_TTL_SECONDS=300
DOWNLOAD_CAPABILITY_TTL_SECONDS=60
MAX_UPLOAD_BYTES=100000000
FILE_CAPABILITY_ORIGINS=https://objects.example.invalid
SEARCH_CURSOR_TTL_SECONDS=300
SEARCH_MAX_RESPONSE_BYTES=65536
SEARCH_MAX_TITLE_BYTES=512
SEARCH_MAX_SNIPPET_BYTES=4096

# Abuse controls and browser session boundaries
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
WEBHOOK_MAX_SKEW_SECONDS=300
SESSION_COOKIE_NAME=__Host-session
CSRF_COOKIE_NAME=__Host-csrf
SESSION_FRESH_AUTH_MAX_AGE_SECONDS=300
READINESS_TIMEOUT_MS=2000
# READINESS_TOKEN is required in production and must come from secret storage.

# Telemetry is fail-closed: enabling it requires an approved HTTPS collector endpoint.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=project-conversation-gateway
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://telemetry.example.invalid/v1/traces

# The gateway will not start without a reviewed adapter composition module.
# GATEWAY_ADAPTER_MODULE=/app/adapters/production.mjs

# Worker process
WORKER_ENVIRONMENT=development
WORKER_ID=worker-local-1
WORKER_HEALTH_HOST=127.0.0.1
WORKER_HEALTH_PORT=8081
WORKER_POLL_INTERVAL_MS=500
WORKER_CLAIM_TIMEOUT_MS=5000
WORKER_READINESS_TIMEOUT_MS=2000
WORKER_LEASE_MS=30000
WORKER_HEARTBEAT_MS=10000
WORKER_MAX_ATTEMPTS=8
WORKER_MAX_JOB_AGE_MS=604800000
WORKER_BACKOFF_BASE_MS=1000
WORKER_BACKOFF_CAP_MS=300000
WORKER_BACKOFF_JITTER_RATIO=0.2
WORKER_CHECKPOINT_MS=2000
AGENT_MAX_CONTEXT_BYTES=1000000
AGENT_MAX_OUTPUT_TOKENS=16000
AGENT_MAX_TOOL_CALLS=32
AGENT_MAX_RUN_COST_MICROS=5000000
WORKER_LOG_LEVEL=info
# The worker will not start without a reviewed complete adapter composition module.
# WORKER_ADAPTER_MODULE=/app/adapters/production.mjs
# Production worker adapter/storage/model/email/search/object credentials are deliberately omitted.
